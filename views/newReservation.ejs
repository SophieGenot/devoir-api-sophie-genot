<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Créer une réservation</title>

  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
 <header class="header-hero">
    <div class="header-overlay">
      <h1>Port de Russell</h1>
      <p>Bienvenue sur la page du port de Russell</p>
    </div>
  </header>

  <main>
    <section></section>
  </main>
  <section>
     <h1>Créer une nouvelle réservation</h1>

  <form action="/reservations/new" method="POST">
    <table>
      <tbody>
        <tr>
          <th>Numéro du catway</th>
         <td>
              <input
                type="number"
                name="catwayNumber"
                min="1"
                max="24"
                value="<%= reservation.catwayNumber || '' %>"
                required
              >
              <% if (errors && errors.catwayNumber) { %>
                <div class="error-message"><%= errors.catwayNumber %></div>
              <% } %>
            </td>
        </tr>
  </section>
 
  <section>
    <tr>
          <th>Nom du client</th>
          <td>
            <input type="text" name="clientName" required>
          </td>
        </tr>
  </section>
        
  <section>
    <tr>
          <th>Email du client</th>
          <td>
            <input type="email" name="clientEmail" required>
          </td>
        </tr>
  </section>
        
  <section>
    <tr>
          <th>Nom du bateau</th>
          <td>
             <select name="boatName" required>
      <option value="">-- Sélectionner un bateau --</option>
      <% boats.forEach(boat => { %>
        <option value="<%= boat.name %>" 
          <%= reservation.boatName === boat.name ? 'selected' : '' %>>
          <%= boat.name %>
        </option>
      <% }) %>
    </select>
    <% if (errors.boatName) { %>
      <div class="error"><%= errors.boatName %></div>
    <% } %>
     </td>
 
    </tr>
  </section>
        
  <section>
    <!-- Start Date -->
          <tr>
            <th>Date de début</th>
            <td>
              <input
                type="date"
                id="startDate"
                name="startDate"
                value="<%= reservation.startDate || '' %>"
                required
              >
              <% if (errors && errors.startDate) { %>
                <div class="error-message"><%= errors.startDate %></div>
              <% } %>
            </td>
          </tr>

          <!-- End Date -->
          <tr>
            <th>Date de fin</th>
            <td>
              <input
                type="date"
                id="endDate"
                name="endDate"
                value="<%= reservation.endDate || '' %>"
                required
              >
              <% if (errors && errors.endDate) { %>
                <div class="error-message"><%= errors.endDate %></div>
              <% } %>
            </td>
          </tr>
  </section>
    </tbody>
    </table>

    <button type="submit">Créer la réservation</button>
    <a href="/dashboard">
      <button type="button">Annuler</button>
    </a>
  </form>
  
  </section>     

</body>
</html>
